{
  "self_protection": {
    "enabled": true
  },
  "protect": {
    "files": [
      ".zshrc",
      ".zprofile",
      ".bash_profile",
      ".bashrc",
      ".env",
      ".key",
      ".pem",
      ".ssh",
      ".aws",
      ".gnupg",
      ".kube",
      ".gcloud",
      ".npmrc",
      ".netrc",
      ".docker/config.json",
      ".vault-token",
      ".git-credentials"
    ]
  },
  "allow": {
    "read_files": [
      ".claude/settings.json"
    ],
    "repos": {}
  },
  "block": {
    "commands": {
      "rm -rf": "rm -rf",
      "rm -fr": "rm -fr",
      "rm -r": "rm -r",
      "mkfs": "mkfs",
      "dd": "dd",
      "truncate": "truncate",
      "chmod 777": "chmod 777",
      "chown": "chown",
      "git push --force": "git push --force",
      "git reset --hard": "git reset --hard",
      "git clean": "git clean",
      "kubectl delete": "kubectl delete",
      "kubectl drain": "kubectl drain",
      "kubectl scale 0": "kubectl scale 0",
      "kubectl exec": "kubectl exec",
      "kubectl apply": "kubectl apply",
      "helm uninstall": "helm uninstall",
      "docker sys prune": "docker sys prune",
      "brew uninstall": "brew uninstall",
      "curl|wget pipe": "curl|wget pipe",
      "sh < redirect": "sh < redirect",
      "npm publish": "npm publish",
      "gradle publish": "gradle publish",
      "printenv": "printenv",
      "env dump": "env dump",
      "echo secret var": "echo secret var",
      "show-token": "show-token",
      "eval": "eval",
      "sh -c": "sh -c",
      "dot source": "dot source",
      "base64 decode": "base64 decode",
      "printf hex": "printf hex",
      "xxd reverse": "xxd reverse",
      "gh pr merge": "gh pr merge",
      "gh pr close": "gh pr close",
      "gh issue close": "gh issue close",
      "gh issue comment": "gh issue comment",
      "gh repo delete": "gh repo delete",
      "gh release delete": "gh release delete",
      "gh api DELETE": "gh api DELETE",
      "npm install": "npm install",
      "npm i": "npm i",
      "yarn add": "yarn add",
      "pnpm add": "pnpm add",
      "pip install": "pip install",
      "brew install": "brew install",
      "cargo install": "cargo install",
      "terraform destroy": "terraform destroy",
      "terraform apply": "terraform apply",
      "docker exec": "docker exec",
      "docker rm": "docker rm",
      "docker rmi": "docker rmi",
      "sudo": "sudo",
      "killall": "killall",
      "diskutil erase": "diskutil erase",
      "crontab remove": "crontab remove",
      "launchctl unload": "launchctl unload",
      "osascript": "osascript",
      "defaults write": "defaults write",
      "security": "security",
      "mongo shell": "mongo shell",
      "mongosh": "mongosh",
      "psql": "psql",
      "mysql": "mysql",
      "ssh": "ssh",
      "scp": "scp",
      "rsync": "rsync"
    },
    "mcp_writes": {}
  },
  "always_deny": [
    "rm -rf",
    "rm -fr",
    "mkfs",
    "dd",
    "git push --force",
    "curl|wget pipe",
    "sh < redirect",
    "npm publish",
    "gradle publish",
    "printenv",
    "env dump",
    "echo secret var",
    "show-token",
    "eval",
    "base64 decode",
    "printf hex",
    "xxd reverse",
    "gh repo delete",
    "gh release delete",
    "gh api DELETE",
    "terraform destroy",
    "sudo",
    "diskutil erase",
    "crontab remove"
  ],
  "advanced": {
    "command_regex": {},
    "file_regex": {}
  }
}
