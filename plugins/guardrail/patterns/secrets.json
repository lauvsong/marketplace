{
  "description": "git commit 직전 staged diff 의 추가된 라인에서 검사할 시크릿 정규식. 매칭되면 커밋 차단.",
  "patterns": {
    "AWS access key":           "\\bAKIA[0-9A-Z]{16}\\b",
    "AWS secret key":           "(?i)aws[_-]?secret[_-]?(access[_-]?)?key[\"']?\\s*[:=]\\s*[\"']?[A-Za-z0-9/+=]{40}\\b",
    "Google API key":           "\\bAIza[0-9A-Za-z\\-_]{35}\\b",
    "OpenAI API key":           "\\bsk-[A-Za-z0-9]{20,}T3BlbkFJ[A-Za-z0-9]{20,}\\b",
    "Anthropic API key":        "\\bsk-ant-(api|admin)[0-9]{2}-[A-Za-z0-9\\-_]{80,}\\b",
    "GitHub PAT (classic)":     "\\bghp_[A-Za-z0-9]{36}\\b",
    "GitHub PAT (fine-grained)":"\\bgithub_pat_[A-Za-z0-9_]{82}\\b",
    "GitHub OAuth":             "\\bgho_[A-Za-z0-9]{36}\\b",
    "GitHub user token":        "\\bghu_[A-Za-z0-9]{36}\\b",
    "GitHub refresh token":     "\\bghr_[A-Za-z0-9]{36}\\b",
    "GitHub server token":      "\\bghs_[A-Za-z0-9]{36}\\b",
    "Slack token":              "\\bxox[abprs]-[A-Za-z0-9-]{10,}\\b",
    "Stripe secret key":        "\\bsk_(live|test)_[A-Za-z0-9]{20,}\\b",
    "Stripe restricted key":    "\\brk_(live|test)_[A-Za-z0-9]{20,}\\b",
    "1Password service token":  "\\bops_[A-Za-z0-9]{40,}\\b",
    "PEM private key block":    "-----BEGIN (RSA |DSA |EC |OPENSSH |PGP )?PRIVATE KEY( BLOCK)?-----",
    "Hex private key (64ch)":   "(?i)(private[_-]?key|priv[_-]?key)[\"']?\\s*[:=]\\s*[\"']?[a-f0-9]{64}\\b",
    "Generic api_key var":      "(?i)(api[_-]?key|access[_-]?token|auth[_-]?token|secret[_-]?key)[\"']?\\s*[:=]\\s*[\"'][A-Za-z0-9_\\-+/=]{16,}[\"']",
    "JWT token":                "\\beyJ[A-Za-z0-9_\\-]{10,}\\.eyJ[A-Za-z0-9_\\-]{10,}\\.[A-Za-z0-9_\\-]{10,}\\b"
  }
}
